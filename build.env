# Identity
DEVICE_NAME="annibale"
ARCH="arm64"

# Compiler knobs
KCFLAGS="-Wno-error -D__ANDROID_COMMON_KERNEL__"
HOSTCFLAGS="-Wno-error"

# SoC/platform-specific kbuild symbols
EXTRA_KBUILD_FLAGS="CONFIG_ARCH_SUN=y"

# Out-of-tree module source directories
OOT_MODULE_DIRS=("sm8750-modules")

# Ordered build list for OOT modules
DLKM_SOURCES=(
    # Sorted by module symbol dependencies
    "sm8750-modules/qcom/opensource/data-kernel/drivers/smem-mailbox:vendor_dlkm:SMEM_MAILBOX_ROOT"
    "sm8750-modules/qcom/opensource/mm-drivers/msm_ext_display:vendor_dlkm:MM_DRIVERS_ROOT"
    "sm8750-modules/qcom/opensource/mm-drivers/hw_fence:vendor_dlkm:MM_DRIVERS_ROOT"
    "sm8750-modules/qcom/opensource/mm-drivers/sync_fence:vendor_dlkm:MM_DRIVERS_ROOT"
    "sm8750-modules/qcom/opensource/mmrm-driver:vendor_dlkm:MMRM_ROOT"
    "sm8750-modules/qcom/opensource/synx-kernel:vendor_dlkm:SYNX_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/securemsm-kernel:vendor_dlkm:SSG_ROOT"
    "sm8750-modules/qcom/opensource/audio-kernel:vendor_dlkm:AUDIO_ROOT"
    "sm8750-modules/qcom/opensource/camera-kernel:vendor_dlkm:CAMERA_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/display-drivers:vendor_dlkm:DISPLAY_ROOT"
    "sm8750-modules/qcom/opensource/video-driver/msm_video:vendor_dlkm:VIDEO_ROOT"
    "sm8750-modules/qcom/opensource/video-driver/video:vendor_dlkm:VIDEO_ROOT"
    "sm8750-modules/qcom/opensource/wlan/qcacld-3.0:vendor_dlkm:WLAN_ROOT"
    "sm8750-modules/qcom/opensource/wlan/platform:vendor_dlkm:WLAN_PLATFORM_ROOT"
    "sm8750-modules/qcom/opensource/graphics-kernel:vendor_dlkm:KGSL_PATH"
    "sm8750-modules/qcom/opensource/fingerprint:vendor_dlkm:FINGERPRINT_ROOT"
    "sm8750-modules/qcom/opensource/securemsm-kernel:vendor_dlkm:SSG_ROOT"
    "sm8750-modules/qcom/opensource/synx-kernel:vendor_dlkm:SYNX_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/mmrm-driver:vendor_dlkm:MMRM_ROOT"
    "sm8750-modules/qcom/opensource/data-kernel/drivers/smem-mailbox:vendor_dlkm:SMEM_MAILBOX_ROOT"
    "sm8750-modules/qcom/opensource/dsp-kernel:vendor_dlkm:DSP_ROOT"
    "sm8750-modules/qcom/opensource/eva-kernel:vendor_dlkm:EVA_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/bt-kernel:vendor_dlkm:BT_ROOT"
    "sm8750-modules/qcom/opensource/spu-kernel:vendor_dlkm:SPU_ROOT"
    "sm8750-modules/qcom/opensource/touch-drivers:vendor_dlkm:TOUCH_ROOT"
)

# Output and Tooling Paths
OUT_DIR="/media/harumajati/NVME/Workspace/dada/out"
DIST_DIR="/media/harumajati/NVME/Workspace/dada/dist"
VENDOR_DLKM_MODULES_LIST="/media/harumajati/NVME/Workspace/dada/modules.list.msm.annibale"
AOSP_TOOLS_DIR="/media/harumajati/NVME/Workspace/dada/build-tools/linux_musl-x86/bin"

# Image Configuration
BOOT_HEADER_VERSION="4"
KERNEL_IMAGE_NAME="Image"
PARTITION_SIZE="536870912"

# DTS Configuration
DTS_OUT_DIR="arch/arm64/boot/dts/vendor/qcom"
MKDTBOIMG_OPTIONS="--page_size=4096"
DTBO_LIST=(
    "annibale-sm8750-overlay.dtbo"
)
DTB_LIST=(
    "sun.dtb"
    "sun-v2.dtb"
    "sun-tp.dtb"
    "sun-tp-v2.dtb"
    "sunp.dtb"
    "sunp-v2.dtb"
    "sunp-tp.dtb"
    "sunp-tp-v2.dtb"
)
