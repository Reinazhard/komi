# ==================================================
# Unified Build Environment Configuration
# ==================================================

# --- Identity & Architecture ---
# The name of the target device and target architecture
DEVICE_NAME="annibale"
ARCH="arm64"

# --- Compiler & Kbuild Configuration ---
# Optimization flags and Android-specific kernel defines
KCFLAGS="-Wno-error -D__ANDROID_COMMON_KERNEL__"
HOSTCFLAGS="-Wno-error"

# SoC or platform-specific kbuild symbols (e.g., CONFIG_ARCH_X=y)
EXTRA_KBUILD_FLAGS="CONFIG_ARCH_SUN=y"

# --- Output & Tooling Paths ---
# Internal build output and final distribution artifact directories
OUT_DIR="/media/harumajati/NVME/Workspace/dada/out"
DIST_DIR="/media/harumajati/NVME/Workspace/dada/dist"

# Path to AOSP kernel build tools (mkbootimg, avbtool, etc.)
AOSP_TOOLS_DIR="$CWD/tools"

# --- Image & Partition Configuration ---
# Header version for boot.img and vendor_boot.img
BOOT_HEADER_VERSION="4"

# Name of the primary kernel image to be packaged
KERNEL_IMAGE_NAME="Image"

# Default partition size (in bytes) for generated images
PARTITION_SIZE="536870912"

# --- DTB & DTBO Configuration ---
# Directory under $OUT_DIR where compiled DTBs are located
DTS_OUT_DIR="arch/arm64/boot/dts/vendor/qcom"

# Options passed to mkdtboimg during dtbo.img creation
MKDTBOIMG_OPTIONS="--page_size=4096"

# List of DTBO overlays to be included in dtbo.img
DTBO_LIST=(
    "annibale-sm8750-overlay.dtbo"
)

# List of DTBs to be concatenated and included in vendor_boot.img
DTB_LIST=(
    "sun.dtb"
    "sun-v2.dtb"
    "sun-tp.dtb"
    "sun-tp-v2.dtb"
    "sunp.dtb"
    "sunp-v2.dtb"
    "sunp-tp.dtb"
    "sunp-tp-v2.dtb"
)

# --- Module Staging & Partitioning ---
# Filesystem types for DLKM images (ext4, erofs)
SYSTEM_DLKM_FS_TYPE="erofs"
VENDOR_DLKM_FS_TYPE="erofs"

# Set to 1 to generate flat /lib/modules layout instead of nested extra/kernel dirs
SYSTEM_DLKM_GEN_FLATTEN_IMAGE=1
VENDOR_DLKM_GEN_FLATTEN_IMAGE=0

# List of modules to be included in the system_dlkm partition
SYSTEM_DLKM_MODULES_LIST="/media/harumajati/NVME/Workspace/dada/annibale/system_dlkm/modules.load"
SYSTEM_DLKM_MODULES_BLOCKLIST=""

# List of modules to be included in the vendor_dlkm partition
VENDOR_DLKM_MODULES_LIST="/media/harumajati/NVME/Workspace/dada/annibale/vendor_dlkm/modules.load"
VENDOR_DLKM_MODULES_BLOCKLIST="/media/harumajati/NVME/Workspace/dada/annibale/vendor_dlkm/modules.blocklist"

# List of critical modules for vendor_boot ramdisk and recovery loading
VENDOR_BOOT_MODULES_LIST="/media/harumajati/NVME/Workspace/dada/annibale/vendor_boot/modules.load"
VENDOR_BOOT_MODULES_BLOCKLIST=""
MODULES_RECOVERY_LIST="/media/harumajati/NVME/Workspace/dada/annibale/vendor_boot/modules.load.recovery"

# Generic blocklist for all partitions (fallback)
MODULES_BLOCKLIST=""

# --- Out-of-tree (OOT) Modules ---
# List of directories containing OOT module source code
OOT_MODULE_DIRS=("sm8750-modules")

# Structured list of OOT modules to build and their target partitions
# Format: "source_path:target_partition:ROOT_VARIABLE"
DLKM_SOURCES=(
    "sm8750-modules/qcom/opensource/data-kernel/drivers/smem-mailbox:vendor_dlkm:SMEM_MAILBOX_ROOT"
    "sm8750-modules/qcom/opensource/mm-drivers/msm_ext_display:vendor_dlkm:MM_DRIVERS_ROOT"
    "sm8750-modules/qcom/opensource/mm-drivers/hw_fence:vendor_dlkm:MM_DRIVERS_ROOT"
    "sm8750-modules/qcom/opensource/mm-drivers/sync_fence:vendor_dlkm:MM_DRIVERS_ROOT"
    "sm8750-modules/qcom/opensource/mmrm-driver:vendor_dlkm:MMRM_ROOT"
    "sm8750-modules/qcom/opensource/synx-kernel:vendor_dlkm:SYNX_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/securemsm-kernel:vendor_dlkm:SSG_ROOT"
    "sm8750-modules/qcom/opensource/audio-kernel:vendor_dlkm:AUDIO_ROOT"
    "sm8750-modules/qcom/opensource/camera-kernel:vendor_dlkm:CAMERA_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/display-drivers:vendor_dlkm:DISPLAY_ROOT"
    "sm8750-modules/qcom/opensource/video-driver/msm_video:vendor_dlkm:VIDEO_ROOT"
    "sm8750-modules/qcom/opensource/video-driver/video:vendor_dlkm:VIDEO_ROOT"
    "sm8750-modules/qcom/opensource/wlan/qcacld-3.0:vendor_dlkm:WLAN_ROOT"
    "sm8750-modules/qcom/opensource/wlan/platform:vendor_dlkm:WLAN_PLATFORM_ROOT"
    "sm8750-modules/qcom/opensource/graphics-kernel:vendor_dlkm:KGSL_PATH"
    "sm8750-modules/qcom/opensource/fingerprint:vendor_dlkm:FINGERPRINT_ROOT"
    "sm8750-modules/qcom/opensource/securemsm-kernel:vendor_dlkm:SSG_ROOT"
    "sm8750-modules/qcom/opensource/synx-kernel:vendor_dlkm:SYNX_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/mmrm-driver:vendor_dlkm:MMRM_ROOT"
    "sm8750-modules/qcom/opensource/data-kernel/drivers/smem-mailbox:vendor_dlkm:SMEM_MAILBOX_ROOT"
    "sm8750-modules/qcom/opensource/dsp-kernel:vendor_dlkm:DSP_ROOT"
    "sm8750-modules/qcom/opensource/eva-kernel:vendor_dlkm:EVA_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/bt-kernel:vendor_dlkm:BT_ROOT"
    "sm8750-modules/qcom/opensource/spu-kernel:vendor_dlkm:SPU_ROOT"
    "sm8750-modules/qcom/opensource/touch-drivers:vendor_dlkm:TOUCH_ROOT"
    "sm8750-modules/nxp/opensource/driver/:vendor_dlkm:"
)
