# ==================================================
# Unified Build Environment Configuration
# ==================================================

# --- Identity & Architecture ---
DEVICE_NAME="annibale"
ARCH="arm64"

# --- Compiler & Kbuild Configuration ---
KCFLAGS="-Wno-error -D__ANDROID_COMMON_KERNEL__"
HOSTCFLAGS="-Wno-error"

# Set to 1 to use LLVM/Clang, 0 to use GCC
LLVM=1
LLVM_IAS=1

# GCC toolchain prefixes (only used if LLVM=0)
CROSS_COMPILE=""
CROSS_COMPILE_COMPAT=""

# SoC or platform-specific kbuild symbols (e.g., CONFIG_ARCH_X=y)
EXTRA_KBUILD_FLAGS="CONFIG_ARCH_SUN=y"

# --- Output & Tooling Paths ---
OUT_DIR="$CWD/out"
DIST_DIR="$CWD/dist"

# Path to AOSP kernel build tools (mkbootimg, avbtool, etc.)
AOSP_TOOLS_DIR="$CWD/build-kernel/tools/bin"

# --- Image & Partition Configuration ---
# Header version for boot.img and vendor_boot.img
BOOT_HEADER_VERSION="4"

# Name of the primary kernel image to be packaged
KERNEL_IMAGE_NAME="Image"

# Default partition size (in bytes) for generated images
PARTITION_SIZE="536870912"

# --- DTB & DTBO Configuration ---
# Directory under $OUT_DIR where compiled DTBs are located
DTS_OUT_DIR="arch/arm64/boot/dts/vendor/qcom"

# Options passed to mkdtboimg during dtbo.img creation
MKDTBOIMG_OPTIONS="--page_size=4096"

# List of DTBO overlays to be included in dtbo.img
DTBO_LIST=(
    "annibale-sm8750-overlay.dtbo"
)

# List of DTBs to be concatenated and included in vendor_boot.img
DTB_LIST=(
    "sun.dtb"
    "sun-v2.dtb"
    "sun-tp.dtb"
    "sun-tp-v2.dtb"
    "sunp.dtb"
    "sunp-v2.dtb"
    "sunp-tp.dtb"
    "sunp-tp-v2.dtb"
)

# --- Module Staging & Partitioning ---
# Filesystem types for DLKM images (ext4, erofs)
SYSTEM_DLKM_FS_TYPE="erofs"
VENDOR_DLKM_FS_TYPE="erofs"

# Set to 1 to generate flat /lib/modules layout instead of nested extra/kernel dirs
SYSTEM_DLKM_GEN_FLATTEN_IMAGE=1
VENDOR_DLKM_GEN_FLATTEN_IMAGE=0

# List of modules to be included in the system_dlkm partition
SYSTEM_DLKM_MODULES_LIST="$CWD/annibale/system_dlkm/modules.load"
SYSTEM_DLKM_MODULES_BLOCKLIST=""

# List of modules to be included in the vendor_dlkm partition
VENDOR_DLKM_MODULES_LIST="$CWD/annibale/vendor_dlkm/modules.load"
VENDOR_DLKM_MODULES_BLOCKLIST="$CWD/annibale/vendor_dlkm/modules.blocklist"

# List of critical modules for vendor_boot ramdisk and recovery loading
VENDOR_BOOT_MODULES_LIST="$CWD/annibale/vendor_boot/modules.load"
VENDOR_BOOT_MODULES_BLOCKLIST=""
MODULES_RECOVERY_LIST="$CWD/annibale/vendor_boot/modules.load.recovery"

# Generic blocklist for all partitions (fallback)
MODULES_BLOCKLIST=""

# --- Out-of-tree (OOT) Modules ---
# List of directories containing OOT module source code
OOT_MODULE_DIRS=("sm8750-modules")

# Structured list of OOT modules to build
# Format: "source_path:ROOT_VARIABLE"
DLKM_SOURCES=(
    "sm8750-modules/qcom/opensource/data-kernel/drivers/smem-mailbox:SMEM_MAILBOX_ROOT"
    "sm8750-modules/qcom/opensource/mm-drivers/msm_ext_display:MM_DRIVERS_ROOT"
    "sm8750-modules/qcom/opensource/mm-drivers/hw_fence:MM_DRIVERS_ROOT"
    "sm8750-modules/qcom/opensource/mm-drivers/sync_fence:MM_DRIVERS_ROOT"
    "sm8750-modules/qcom/opensource/mmrm-driver:MMRM_ROOT"
    "sm8750-modules/qcom/opensource/synx-kernel:SYNX_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/securemsm-kernel:SSG_ROOT"
    "sm8750-modules/qcom/opensource/audio-kernel:AUDIO_ROOT"
    "sm8750-modules/qcom/opensource/camera-kernel:CAMERA_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/display-drivers:DISPLAY_ROOT"
    "sm8750-modules/qcom/opensource/video-driver/msm_video:VIDEO_ROOT"
    "sm8750-modules/qcom/opensource/video-driver/video:VIDEO_ROOT"
    "sm8750-modules/qcom/opensource/wlan/qcacld-3.0:WLAN_ROOT"
    "sm8750-modules/qcom/opensource/wlan/platform:WLAN_PLATFORM_ROOT"
    "sm8750-modules/qcom/opensource/graphics-kernel:KGSL_PATH"
    "sm8750-modules/qcom/opensource/fingerprint:FINGERPRINT_ROOT"
    "sm8750-modules/qcom/opensource/securemsm-kernel:SSG_ROOT"
    "sm8750-modules/qcom/opensource/synx-kernel:SYNX_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/mmrm-driver:MMRM_ROOT"
    "sm8750-modules/qcom/opensource/data-kernel/drivers/smem-mailbox:SMEM_MAILBOX_ROOT"
    "sm8750-modules/qcom/opensource/dsp-kernel:DSP_ROOT"
    "sm8750-modules/qcom/opensource/eva-kernel:EVA_KERNEL_ROOT"
    "sm8750-modules/qcom/opensource/bt-kernel:BT_ROOT"
    "sm8750-modules/qcom/opensource/spu-kernel:SPU_ROOT"
    "sm8750-modules/qcom/opensource/touch-drivers:TOUCH_ROOT"
    "sm8750-modules/nxp/opensource/driver/:"
)
